    {
      "name": "Employee",
      "item": [
        {
          "name": "Create Employee",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Virat\",\n  \"email\": \"virat@gmail.com\",\n  \"salary\": 5000.0,\n  \"departmentId\": {{departmentId}},\n  \"projectIds\": [{{projectId}}]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/employee",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "employee"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"Create Employee returns 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "if (json && json.data && json.data.id) {",
                  "    pm.collectionVariables.set(\"employeeId\", json.data.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get All Employees",
          "request": {
            "method": "GET",
